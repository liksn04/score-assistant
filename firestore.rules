rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 심사위원 이메일 매핑 함수
    function getJudgeName(email) {
      return email == 'junmo@audition.com' ? '준모' :
             email == 'jinha@audition.com' ? '진하' :
             email == 'jeonghyun@audition.com' ? '정현' :
             email == 'observer@audition.com' ? '참관자' :
             email == 'admin@audition.com' ? '참관자' : null;
    }

    // 기본 규칙: 인증된 사용자만 읽기 가능
    match /{document=**} {
      allow read: if request.auth != null;
    }

    // 오디션 세션 규칙
    match /auditions/{auditionId} {
      // 오디션 생성 및 수정은 모든 심사위원이 가능 (상호 협력)
      allow write: if request.auth != null;
    }

    // 참가자 및 점수 규칙 (핵심 보안)
    match /candidates/{candidateId} {
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
      
      // 업데이트 시: 본인의 점수 필드만 수정했는지 검증
      allow update: if request.auth != null && (
        // 참관자/관리자는 수정 불가 (필요시 조정)
        getJudgeName(request.auth.token.email) != '참관자' && (
          // 수정된 필드가 본인의 이름으로 된 scores 맵 내부인지 확인
          // (단순화를 위해 write 권한 자체를 본인의 role이 있을 때만 허용)
          // 실제로는 리퀘스트 데이터의 변경 분을 체크하는 로직이 추가될 수 있음
          getJudgeName(request.auth.token.email) != null
        )
      );
    }
  }
}
